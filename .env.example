# Flask Web App — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.

# ----- Core Flask -----
FLASK_CONFIG=config.DevelopmentConfig
SECRET_KEY=change-me-in-production-use-a-long-random-string

# ----- Database -----
# SQLite (development default — no setup required)
DATABASE_URL=sqlite:///dev.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/myapp

# ----- Flask env -----
FLASK_ENV=development
FLASK_DEBUG=1

# ----- Seed credentials (development only) -----
# admin  / admin123
# alice  / alice123
# bob    / bob12345
